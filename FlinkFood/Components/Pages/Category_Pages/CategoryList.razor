@page "/Category"
@using FlinkFood.Services
@using FlinkFood.Services.Extensions
@using FlinkFood.Utilities
@using Microsoft.AspNetCore.Authorization
@inject CategoryService svc
@inject ISnackbar Snackbar
@attribute [Authorize(Roles = SD.Role_Admin)]

@if (IsProcessing)
{
    <div class="position-absolute w-75 h-75 d-flex flex-column align-items-center bg-white justify-content-center">
        <img src="/images/loading.gif" alt="loading" />
    </div>
}
else
{
    <div class="card shadow border-0 mt-4">
        <div class="card-header bg-black bg-gradient m-l-0 py-3">
            <div class="row">
                <div class="col-12 text-center">
                    <h2 class="text-white py-2">Category List</h2>
                </div>
            </div>
        </div>

        <div class="card-body p-4">
            <div class="row pb-3">
                <div class="col-12 text-end">
                    <a href="/category/create" class="btn btn-secondary" style="width:200px"><i class="bi bi-plus-circle"></i> Add New Category</a>
                </div>

            </div>
            @if (category.Any())
            {
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Emoji</th>
                            <th>Name</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in category)
                        {
                            <tr>
                                <td>@item.Emoji</td>
                                <td>@item.Name</td>
                                <td>
                                    <a href="/category/update/@item.Id" class="btn btn-primary"><i class="bi bi-pencil"></i> Edit</a>
                                    <button class="btn btn-danger" @onclick="()=>Delete(item.Id)"><i class="bi bi-trash-fill"></i> Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            }
            else
            {
                <p>No Category For the moment</p>
            }
        </div>
    </div>
}

@code {
    public bool IsProcessing { get; set; } = false;
    private List<Category> category = new();

    protected override async Task OnInitializedAsync()
    {
        IsProcessing = true;
        await Task.Delay(2000);
        await LoadCategory();
        IsProcessing = false;
    }

    private async Task LoadCategory()
    {
        var result = await svc.GetAll();
        category = result.ToList();
    }
    private async Task Delete(int id)
    {
        try
        {
            var obj = await svc.GetById(id);
            await svc.DeleteCategoryAsync(obj);

            Snackbar.Add($"{obj.Name} deleted successfully", Severity.Success);

            await LoadCategory();
        }
        catch (NotFoundException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        catch (Exception)
        {
            Snackbar.Add("Unexpected error", Severity.Error);
        }

    }

}
