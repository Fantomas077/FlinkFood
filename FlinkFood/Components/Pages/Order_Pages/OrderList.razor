@page "/order-list"
@using System.Security.Claims
@inject OrderService OrderService
@inject AuthenticationStateProvider _auth
@using FlinkFood.Utilities
@using Microsoft.AspNetCore.Authorization
@inject NavigationManager _Nav
@attribute [Authorize]

<div class="container py-4">

    <h2 class="text-success fw-bold mb-4 text-center">
        📦 Bestellungen
        @if (isAdmin)
        {
            <span class="text-muted">(Admin)</span>
        }
    </h2>

    @if (orders == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-success"></div>
        </div>
    }
    else if (!orders.Any())
    {
        <div class="alert alert-info text-center py-4 fs-5">
            Keine Bestellungen gefunden.
        </div>
    }
    else
    {
        <RadzenDataGrid AllowFiltering="true" Pages AllowColumnResize="true" AllowAlternatingRows="false" FilterMode="FilterMode.Advanced" AllowSorting="true"
        PageSize="3" AllowPaging="true" PagerHorizontalAlign="HorizontalAlign.Left" ShowPagingSummary="true"
                        Data="@orders" ColumnWidth="300px" LogicalFilterOperator="LogicalFilterOperator.Or" SelectionMode="DataGridSelectionMode.Single">
            <Columns>
                <RadzenDataGridColumn TItem="OrderHeader" Property="Id" Title="ID" Width="80px" />

                <RadzenDataGridColumn TItem="OrderHeader" Property="Name" Title="Name" Width="150px" />

                <RadzenDataGridColumn TItem="OrderHeader" Property="Email" Title="Email" Width="200px" />

                <RadzenDataGridColumn TItem="OrderHeader" Property="PhoneNumber" Title="Phone" Width="150px" />

                <RadzenDataGridColumn TItem="OrderHeader" Property="Orderdate" Title="Datum" Width="180px">
                    <Template Context="order">
                        @order.Orderdate.ToString("dd.MM.yyyy HH:mm")
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="OrderHeader" Property="Status" Title="Status" Width="150px">
                    <Template Context="order">
                        <span class="badge bg-primary">@order.Status</span>
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="OrderHeader" Property="OrderTotal" Title="Total" Width="120px">
                    <Template Context="order">
                        <span class="fw-bold text-danger">@order.OrderTotal €</span>
                    </Template>
                </RadzenDataGridColumn>



                <RadzenDataGridColumn TItem="OrderHeader" Title="Aktion" Width="350px" Filterable="false" Sortable="false">
                    <Template Context="order">

                        @if (isAdmin)
                        {
                            @* PENDING → READY *@
                            if (order.Status == Status.Pending)
                            {
                                <RadzenButton Text="Bereit"
                                              ButtonStyle="ButtonStyle.Warning"
                                              Click="@(args => ChangeStatus(order.Id, Status.ReadyForPickUp))"
                                              Style="margin-right:5px" />
                            }

                            @* READY → COMPLETED *@
                            if (order.Status == Status.ReadyForPickUp)
                            {
                                <RadzenButton Text="Fertig"
                                              ButtonStyle="ButtonStyle.Success"
                                              Click="@(args => ChangeStatus(order.Id, Status.Completed))"
                                              Style="margin-right:5px" />
                            }

                            @* CANCEL *@
                            if (order.Status != Status.Completed && order.Status != Status.Cancelled)
                            {
                                <RadzenButton Text="Stornieren"
                                              ButtonStyle="ButtonStyle.Danger"
                                              Click="@(args => ChangeStatus(order.Id, Status.Cancelled))"
                                              Style="margin-right:5px" />
                            }
                        }

                        <RadzenButton Text="Details"
                                      ButtonStyle="ButtonStyle.Info"
                                      Click="@(() => _Nav.NavigateTo($"/order-confirmation/{order.Id}"))" />
                    </Template>
                </RadzenDataGridColumn>

                
          

            </Columns>
        </RadzenDataGrid>





    }
</div>

@code {
    private IEnumerable<OrderHeader>? orders;
    private bool isAdmin = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        var authState = await _auth.GetAuthenticationStateAsync();
        var user = authState.User;

        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        var role = user.FindFirst(ClaimTypes.Role)?.Value;

        isAdmin = role == SD.Role_Admin;

        if (isAdmin)
        {
            orders = await OrderService.GettAllAsync();
        }
        else
        {
            if (userId == null)
                return;

            orders = await OrderService.GetByUser(userId);
        }
    }

    private async Task ChangeStatus(int id, Status newStatus)
    {
        await OrderService.UpdateStatus(id, newStatus);
        await LoadOrders(); // refresh
        StateHasChanged();
    }
}
