@page "/cart"
@using Microsoft.AspNetCore.Authorization
@inject ShoppingCartService CartService
@inject ProductService ProductService
@inject ISnackbar Snackbar
@attribute [Authorize]

<div class="container py-4">

    <h2 class="text-success fw-bold mb-4 text-center">
        🛒 Dein Warenkorb
    </h2>

    <div class="row">

        <!-- LEFT SIDE : CART ITEMS -->
        <div class="col-lg-7 col-12">

            @if (!cartItems.Any())
            {
                <div class="alert alert-info text-center py-4 fs-5">
                    Dein Warenkorb ist leer.
                </div>
            }
            else
            {
                @foreach (var item in cartItems)
                {
                    var product = products.First(p => p.Id == item.ProductId);

                    <div class="card shadow-sm mb-3 border-1">
                        <div class="card-body d-flex align-items-center">

                            <!-- IMAGE -->
                            <img src="/images/product/@product.ImageUrl"
                                 class="rounded"
                                 style="width: 90px; height: 90px; object-fit: contain;" />

                            <!-- PRODUCT INFO -->
                            <div class="ms-3 flex-grow-1">
                                <h5 class="fw-bold mb-1">@item.Product.Name</h5>
                                <p class="text-muted small mb-1">@product.Price € / Stück</p>

                                <h5 class="text-danger fw-bold">
                                    @((item.Count * product.Price).ToString("0.00")) €
                                </h5>
                            </div>

                            <!-- QUANTITY CONTROLS -->
                            <div class="d-flex align-items-center">

                                <button class="btn btn-outline-secondary rounded-circle"
                                        style="width: 36px; height: 36px;"
                                        @onclick="() => Decrease(item)">
                                    <i class="bi bi-dash"></i>
                                </button>

                                <span class="mx-3 fw-bold fs-5">@item.Count</span>

                                <button class="btn btn-outline-secondary rounded-circle"
                                        style="width: 36px; height: 36px;"
                                        @onclick="() => Increase(item)">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </div>

                            <!-- REMOVE BUTTON -->
                            <button class="btn btn-outline-danger ms-3"
                                    @onclick="() => Remove(item.ProductId)">
                                <i class="bi bi-trash"></i>
                            </button>

                        </div>
                    </div>
                }
            }
        </div>

        <!-- RIGHT SIDE : SUMMARY -->
        <div class="col-lg-5 col-12">

            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white text-center fs-4 fw-bold">
                    Zusammenfassung
                </div>

                <div class="card-body">

                    <div class="d-flex justify-content-between mb-2">
                        <span class="fw-bold">Artikel insgesamt:</span>
                        <span>@TotalCount</span>
                    </div>

                    <div class="d-flex justify-content-between mb-3">
                        <span class="fw-bold">Gesamtpreis:</span>
                        <span class="text-danger fw-bold fs-5">@TotalPrice €</span>
                    </div>

                    <hr />

                    <h5 class="fw-bold mb-3">Abholinformationen</h5>

                    <EditForm Model="orderHearder" OnValidSubmit="Submit">
                        <DataAnnotationsValidator/>
                        <ValidationSummary/>
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <InputText @bind-Value="orderHearder.Name" type="text" class="form-control" />
                            <ValidationMessage For="()=>orderHearder.Name"/>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <InputText @bind-Value="orderHearder.Email" class="form-control" />
                            <ValidationMessage For="() => orderHearder.Email" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Telefon</label>
                            <InputText @bind-Value="orderHearder.PhoneNumber" type="text" class="form-control" />
                            <ValidationMessage For="() => orderHearder.PhoneNumber" />
                        </div>

                        <button class="btn btn-success w-100 py-2 mt-3 fs-5" type="submit">
                            Bestellung abschließen
                        </button>
                    </EditForm>


                </div>
            </div>

        </div>

    </div>
</div>

@code {
    private List<ShoppingCart> cartItems = new();
    private List<Product> products = new();
    [SupplyParameterFromForm]
    private OrderHeader orderHearder { get; set; } =new();

    protected override async Task OnInitializedAsync()
    {
        CartService.OnChange += RefreshCart;
        await LoadCart();
    }

    private async Task LoadCart()
    {
        cartItems = await CartService.GetCartAsync();

        var allProducts = await ProductService.GetAll();
        products = allProducts
            .Where(p => cartItems.Any(c => c.ProductId == p.Id))
            .ToList();
    }

    private async Task RefreshCart()
    {
        await LoadCart();
        StateHasChanged();
    }

    private async Task Increase(ShoppingCart item)
    {
        item.Count++;
        await CartService.UpdateItemAsync(item);
    }

    private async Task Decrease(ShoppingCart item)
    {
        if (item.Count > 1)
        {
            item.Count--;
            await CartService.UpdateItemAsync(item);
        }
        else
        {
            await CartService.RemoveFromCartAsync(item.ProductId);
        }
        await RefreshCart();
    }

    private async Task Remove(int productId)
    {
        var obj = await ProductService.GetById(productId);
        await CartService.RemoveFromCartAsync(productId);
        Snackbar.Add($"{obj.Name} wurde entfernt", Severity.Success);
        await RefreshCart();
    }

    private decimal TotalPrice => cartItems.Sum(i => i.Count * products.First(p => p.Id == i.ProductId).Price);
    private int TotalCount => cartItems.Sum(i => i.Count);

    public void Dispose()
    {
        CartService.OnChange -= RefreshCart;
    }
    private async Task Submit()
    {


    }
   
}
